{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prestart": "yarn build",
    "clean": "rimraf dist",
    "build": "yarn clean && tsc",
    "start": "node dist/index.js",
    "postinstall": "npx prisma generate",
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts,json --exec \"tsx src/index.ts\"",
    "prod": "NODE_ENV=production node dist/index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "dotenv -e .env --  prisma migrate",
    "prisma:migrate:dev": "dotenv -e .env --  prisma migrate dev",
    "prisma:migrate:dep": "dotenv -e .env --  prisma migrate deploy",
    "prisma:studio": "dotenv -e .env --  prisma studio",
    "prisma:reset": "dotenv -e .env --  prisma migrate reset",
    "prisma:format": "dotenv -e .env -- prisma format",
    "prisma:db:push": "dotenv -e .env --  prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
